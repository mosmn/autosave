---
/**
 * City landing pages (Arabic — default locale).
 * Generates /services/[city] for Riyadh only.
 */
import { getIndexableCities } from '../../data/cities';
import CityTemplate from '../../layouts/CityTemplate.astro';

export function getStaticPaths() {
  return getIndexableCities().map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;
---

<CityTemplate city={city} lang="ar" />
