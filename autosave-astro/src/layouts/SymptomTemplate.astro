---
/**
 * SymptomTemplate — layout template for symptom/problem pages.
 * Renders a full SEO-optimized page for a specific AC symptom.
 * Route: /symptoms/[symptom] and /en/symptoms/[symptom]
 */
import PageLayout from './PageLayout.astro';
import ProgrammaticHero from '../components/programmatic/ProgrammaticHero.astro';
import FAQSection from '../components/programmatic/FAQSection.astro';
import CTAWhatsApp from '../components/programmatic/CTAWhatsApp.astro';
import RelatedLinks from '../components/programmatic/RelatedLinks.astro';
import PriceTable from '../components/programmatic/PriceTable.astro';
import type { Symptom } from '../data/symptoms';
import type { Language } from '../lib/i18n';
import { symptoms, getSymptomBySlug } from '../data/symptoms';
import { getComponentBySlug } from '../data/components';
import { getSymptomSeoByFamily, shouldNoindexThinContent } from '../lib/seo-hardening';

interface Props {
  symptom: Symptom;
  lang: Language;
}

const { symptom, lang } = Astro.props;
const isAr = lang === 'ar';

const symptomTitle = isAr ? symptom.titleAr : symptom.titleEn;
const pageDescription = isAr ? symptom.descriptionAr : symptom.descriptionEn;
const symptomSeo = getSymptomSeoByFamily(symptom.slug, symptomTitle, lang);
const pageTitle = symptomSeo.title;
const metaDescription = symptomSeo.description;

const breadcrumbs = [
  { label: isAr ? 'الرئيسية' : 'Home', href: isAr ? '/' : '/en' },
  { label: isAr ? 'الأعراض' : 'Symptoms', href: isAr ? '/symptoms' : '/en/symptoms' },
  { label: symptomTitle },
];

const whatsappMessage = isAr
  ? `السلام عليكم، عندي مشكلة: ${symptomTitle}`
  : `Hi, I have an issue: ${symptomTitle}`;

// Likelihood label & color
function getLikelihoodLabel(likelihood: string) {
  if (isAr) {
    return likelihood === 'high' ? 'احتمال عالي' : likelihood === 'medium' ? 'احتمال متوسط' : 'احتمال منخفض';
  }
  return likelihood === 'high' ? 'High likelihood' : likelihood === 'medium' ? 'Medium likelihood' : 'Low likelihood';
}

function getLikelihoodColor(likelihood: string) {
  return likelihood === 'high'
    ? 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400'
    : likelihood === 'medium'
      ? 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400'
      : 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400';
}

// Related symptoms
const relatedSymptomLinks = symptom.relatedSymptomSlugs
  .map((slug) => getSymptomBySlug(slug))
  .filter(Boolean)
  .map((s) => ({
    title: isAr ? s!.titleAr : s!.titleEn,
    href: isAr ? `/symptoms/${s!.slug}` : `/en/symptoms/${s!.slug}`,
    description: isAr ? s!.descriptionAr : s!.descriptionEn,
  }));

// Related components
const relatedComponentLinks = symptom.relatedComponentSlugs
  .map((slug) => getComponentBySlug(slug))
  .filter(Boolean)
  .map((c) => ({
    title: isAr ? c!.nameAr : c!.nameEn,
    href: isAr ? `/parts/${c!.slug}` : `/en/parts/${c!.slug}`,
    description: isAr ? c!.descriptionAr : c!.descriptionEn,
  }));

const allRelatedLinks = [...relatedSymptomLinks, ...relatedComponentLinks];
const intentHubLinks = [
  {
    title: isAr ? 'تشخيص أعطال المكيف' : 'AC Diagnostic Service',
    href: isAr ? '/services/ac-diagnostic' : '/en/services/ac-diagnostic',
    description: isAr
      ? 'ابدأ بالتشخيص الفني عند تكرار العرض أو تعدد الاحتمالات.'
      : 'Start with professional diagnosis when recurrence or overlap appears.',
  },
  {
    title: isAr ? 'إصلاح تسريب المكيف' : 'AC Leak Repair',
    href: isAr ? '/services/leak-detection' : '/en/services/leak-detection',
    description: isAr
      ? 'مسار مرتبط بالأعراض التي تشير لفقدان كفاءة التبريد أو تغير الضغط.'
      : 'Relevant when symptoms indicate pressure/cooling efficiency loss.',
  },
  {
    title: isAr ? 'التواصل وحجز الفحص' : 'Contact & Inspection Booking',
    href: isAr ? '/contact' : '/en/contact',
    description: isAr
      ? 'حجز سريع مع وصف العرض لتوجيه الفحص من البداية.'
      : 'Quick booking with symptom context to guide first inspection.',
  },
  ...relatedSymptomLinks.slice(0, 1),
  ...relatedComponentLinks.slice(0, 1),
].filter((link, index, arr) => arr.findIndex((item) => item.href === link.href) === index);

const topCause = symptom.causes[0];
const highLikelihoodCount = symptom.causes.filter((cause) => cause.likelihood === 'high').length;
const mediumLikelihoodCount = symptom.causes.filter((cause) => cause.likelihood === 'medium').length;
const firstDiagnosticStep = (isAr ? symptom.diagnosticStepsAr : symptom.diagnosticStepsEn)[0] ?? '';

const symptomFamily = symptomSeo.familyKey;

const symptomFamilyLeadAr: Record<string, string> = {
  smell: 'هذا النوع يرتبط غالباً بتلوث هوائي داخل النظام.',
  noise: 'هذا النوع يرتبط عادةً بحركة ميكانيكية غير طبيعية.',
  cooling: 'هذا النوع يرتبط بكفاءة تبريد الدورة تحت الحمل الحراري.',
  airflow: 'هذا النوع يرتبط بتدفق الهواء داخل المقصورة.',
  fluid: 'هذا النوع يرتبط بحالة خطوط التبريد والرطوبة والتكاثف.',
  electrical: 'هذا النوع يرتبط بدائرة التحكم والتغذية الكهربائية.',
  load: 'هذا النوع يرتبط بتحميل المحرك عند تشغيل المكيف.',
  general: 'هذا العرض يحتاج مسار فحص تدريجي لتحديد السبب بدقة.',
};

const symptomFamilyLeadEn: Record<string, string> = {
  smell: 'This pattern is often linked to contamination inside the AC airflow path.',
  noise: 'This pattern is usually linked to abnormal mechanical movement.',
  cooling: 'This pattern is linked to cooling-cycle efficiency under heat load.',
  airflow: 'This pattern is linked to cabin airflow delivery.',
  fluid: 'This pattern is linked to refrigerant lines, moisture, and condensate behavior.',
  electrical: 'This pattern is linked to control and power supply circuits.',
  load: 'This pattern is linked to engine load behavior when AC engages.',
  general: 'This symptom requires stepwise diagnosis to confirm the exact cause.',
};

const symptomCueAr: Record<string, string> = {
  smell: 'الروائح',
  noise: 'الأصوات',
  cooling: 'التبريد',
  airflow: 'تدفق الهواء',
  fluid: 'الخطوط والسوائل',
  electrical: 'الدائرة الكهربائية',
  load: 'حمل المحرك',
  general: 'أعراض المكيف',
};

const symptomCueEn: Record<string, string> = {
  smell: 'smell pattern',
  noise: 'noise pattern',
  cooling: 'cooling pattern',
  airflow: 'airflow pattern',
  fluid: 'line/fluid pattern',
  electrical: 'electrical pattern',
  load: 'engine-load pattern',
  general: 'AC symptom pattern',
};

const symptomLeadAr = symptomFamilyLeadAr[symptomFamily];
const symptomLeadEn = symptomFamilyLeadEn[symptomFamily];
const symptomCueArText = symptomCueAr[symptomFamily];
const symptomCueEnText = symptomCueEn[symptomFamily];

// Price range row
const priceRows = [
  {
    label: isAr ? 'تفاصيل الإصلاح' : 'Repair Details',
    details: isAr ? 'تُحدد بعد الفحص الفني حسب السبب' : 'Confirmed after technical inspection based on root cause',
    note: isAr ? 'حسب السبب ونوع السيارة' : 'Depends on cause and vehicle type',
  },
];

const generatedSymptomFaqs = [
  {
    questionAr: `ما أول خطوة لفحص ${symptomCueArText} عند ظهور ${symptomTitle}؟`,
    questionEn: `What is the first step to assess the ${symptomCueEnText} for ${symptomTitle}?`,
    answerAr: firstDiagnosticStep
      ? `${symptomLeadAr} وأول خطوة موصى بها هي: ${firstDiagnosticStep}`
      : `${symptomLeadAr} ابدأ بفحص بصري أساسي لنظام التكييف ثم انتقل إلى التشخيص الفني المتخصص.`,
    answerEn: firstDiagnosticStep
      ? `${symptomLeadEn} The recommended first step is: ${firstDiagnosticStep}`
      : `${symptomLeadEn} Start with a basic visual AC-system check, then proceed to professional diagnostics.`,
  },
  {
    questionAr: `هل ${symptomTitle} يرتبط بسبب واحد أم عدة أسباب محتملة؟`,
    questionEn: `Is ${symptomTitle} linked to one cause or multiple likely causes?`,
    answerAr: topCause
      ? `${symptomLeadAr} غالباً يوجد سبب رئيسي مرجح مثل: ${isAr ? topCause.titleAr : topCause.titleEn}، لكن التأكيد النهائي يتطلب فحصاً عملياً.`
      : `${symptomLeadAr} قد ينتج هذا العرض عن أكثر من سبب، لذلك يلزم تشخيص فني قبل تحديد السبب النهائي.`,
    answerEn: topCause
      ? `${symptomLeadEn} A primary likely cause is often ${isAr ? topCause.titleAr : topCause.titleEn}, but inspection is required because multiple causes can produce the same symptom.`
      : `${symptomLeadEn} This symptom can result from multiple causes, so professional diagnosis is required before confirming the root cause.`,
  },
  {
    questionAr: `متى يجب الانتقال فوراً لتشخيص فني عند ظهور ${symptomTitle}؟`,
    questionEn: `When should you escalate immediately to workshop diagnosis for ${symptomTitle}?`,
    answerAr: `إذا استمر العرض بعد الفحص الأولي، أو ظهر أكثر من ${highLikelihoodCount > 0 ? 'سبب عالي الاحتمال' : 'عرض متزامن'}، فالتشخيص الفني السريع يقلل تكرار المشكلة.`,
    answerEn: `If the symptom persists after initial checks, or more than ${highLikelihoodCount > 0 ? 'one high-likelihood cause profile' : 'one concurrent warning pattern'} appears, prompt workshop diagnosis reduces recurrence risk.`,
  },
];

const mergedSymptomFaqs = [...symptom.faqs, ...generatedSymptomFaqs].filter((faq, index, arr) => {
  const key = isAr ? faq.questionAr.trim() : faq.questionEn.trim();
  return arr.findIndex((item) => (isAr ? item.questionAr.trim() : item.questionEn.trim()) === key) === index;
});

const symptomPrimaryTextLength =
  pageDescription.length +
  symptom.causes
    .map((cause) => (isAr ? cause.explanationAr : cause.explanationEn))
    .join(' ')
    .length +
  (isAr ? symptom.diagnosticStepsAr : symptom.diagnosticStepsEn).join(' ').length;

const symptomKeyBlockCount = [
  symptom.causes.length >= 3,
  (isAr ? symptom.diagnosticStepsAr : symptom.diagnosticStepsEn).length >= 3,
  allRelatedLinks.length >= 2,
].filter(Boolean).length;

const noindexThinSymptom = shouldNoindexThinContent({
  primaryTextLength: symptomPrimaryTextLength,
  faqCount: mergedSymptomFaqs.length,
  keyBlockCount: symptomKeyBlockCount,
  linkHubCount: allRelatedLinks.length + intentHubLinks.length,
});

const symptomSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalSymptom',
  name: symptomTitle,
  description: pageDescription,
  url: Astro.url.href,
  possibleTreatment: {
    '@type': 'MedicalTherapy',
    name: isAr ? 'تشخيص فني لمكيف السيارة' : 'Professional car AC diagnosis',
  },
  associatedAnatomy: {
    '@type': 'AnatomicalSystem',
    name: isAr ? 'نظام تكييف السيارة' : 'Car air conditioning system',
  },
};
---

<PageLayout
  title={pageTitle}
  description={metaDescription}
  lang={lang}
  keywords={isAr ? symptom.keywordsAr : symptom.keywordsEn}
  noindex={noindexThinSymptom}
>
  <ProgrammaticHero
    eyebrow={isAr ? 'مشاكل المكيف' : 'AC Problems'}
    title={symptomTitle}
    description={pageDescription}
    lang={lang}
    breadcrumbs={breadcrumbs}
  />

  <section class="bg-secondary/40 py-20 lg:py-28" data-animate="fade-in-up">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-2xl font-bold text-foreground sm:text-3xl">
        {isAr ? `ملخص تشخيص ${symptomTitle}` : `${symptomTitle} Diagnosis Snapshot`}
      </h2>
      <p class="mt-4 text-muted-foreground">
        {isAr
          ? `يركز هذا الدليل على عرض مسار التشخيص لهذه الحالة فقط، مع الأسباب الأكثر ترجيحاً وخطوات فحص عملية قبل الإصلاح.`
          : `This guide focuses only on the diagnostic path for this symptom, with most likely causes and practical pre-repair inspection steps.`}
      </p>
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-border bg-card p-4 shadow-sm">
          <p class="text-sm text-muted-foreground">{isAr ? 'أسباب عالية الاحتمال' : 'High-likelihood causes'}</p>
          <p class="mt-2 font-display text-2xl font-bold text-foreground">{highLikelihoodCount}</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-4 shadow-sm">
          <p class="text-sm text-muted-foreground">{isAr ? 'أسباب متوسطة الاحتمال' : 'Medium-likelihood causes'}</p>
          <p class="mt-2 font-display text-2xl font-bold text-foreground">{mediumLikelihoodCount}</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-4 shadow-sm">
          <p class="text-sm text-muted-foreground">{isAr ? 'أول سبب للفحص' : 'First cause to inspect'}</p>
          <p class="mt-2 text-sm font-semibold text-foreground">{topCause ? (isAr ? topCause.titleAr : topCause.titleEn) : '-'}</p>
        </div>
      </div>
    </div>
  </section>

  {/* Causes section */}
  <section class="py-20 lg:py-28" data-animate="fade-in-up">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <span class="eyebrow-decorated text-sm font-semibold uppercase tracking-widest text-primary">
          {isAr ? 'التشخيص' : 'Diagnosis'}
        </span>
        <h2 class="mt-4 font-display text-2xl font-bold text-foreground sm:text-3xl">
          {isAr ? 'الأسباب المحتملة' : 'Possible Causes'}
        </h2>
      </div>

      <div class="space-y-4">
        {symptom.causes.map((cause, index) => (
          <div
            class="rounded-xl border border-border bg-card p-5 shadow-sm"
            data-animate="fade-in-up"
            data-animate-delay={String((index + 1) * 100)}
          >
            <div class="flex flex-wrap items-center gap-3">
              <h3 class="font-display text-lg font-semibold text-foreground">
                {isAr ? cause.titleAr : cause.titleEn}
              </h3>
              <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-medium', getLikelihoodColor(cause.likelihood)]}>
                {getLikelihoodLabel(cause.likelihood)}
              </span>
            </div>
            <p class="mt-2 text-muted-foreground">
              {isAr ? cause.explanationAr : cause.explanationEn}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Diagnostic steps */}
  <section class="bg-secondary/40 py-20 lg:py-28" data-animate="fade-in-up">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <span class="eyebrow-decorated text-sm font-semibold uppercase tracking-widest text-primary">
          {isAr ? 'خطوات الفحص' : 'Inspection Steps'}
        </span>
        <h2 class="mt-4 font-display text-2xl font-bold text-foreground sm:text-3xl">
          {isAr ? 'كيف تفحص المشكلة؟' : 'How to Diagnose?'}
        </h2>
      </div>

      <ol class="space-y-4">
        {(isAr ? symptom.diagnosticStepsAr : symptom.diagnosticStepsEn).map((step, index) => (
          <li
            class="flex items-start gap-4 rounded-xl border border-border bg-card p-4 shadow-sm sm:p-5"
            data-animate="fade-in-up"
            data-animate-delay={String((index + 1) * 100)}
          >
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 font-display text-sm font-bold text-primary">
              {index + 1}
            </span>
            <span class="text-foreground">{step}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* Service details */}
  <PriceTable
    rows={priceRows}
    lang={lang}
    title={isAr ? 'تفاصيل الإصلاح' : 'Repair Details'}
  />

  {/* FAQ */}
  {mergedSymptomFaqs.length > 0 && (
    <div class="bg-secondary/40">
      <FAQSection faqs={mergedSymptomFaqs} lang={lang} />
    </div>
  )}

  {/* Related links */}
  {allRelatedLinks.length > 0 && (
    <RelatedLinks links={allRelatedLinks} lang={lang} />
  )}

  {intentHubLinks.length > 0 && (
    <div class="bg-secondary/40">
      <RelatedLinks
        links={intentHubLinks}
        lang={lang}
        title={isAr ? 'روابط الإجراء والتشخيص' : 'Action & Diagnosis Hubs'}
      />
    </div>
  )}

  {/* CTA */}
  <CTAWhatsApp lang={lang} message={whatsappMessage} />

  <script type="application/ld+json" set:html={JSON.stringify(symptomSchema)} />
</PageLayout>
